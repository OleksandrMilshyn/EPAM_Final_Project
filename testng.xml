<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Suite" parallel="tests" thread-count="2">

    <test name="Chrome" parallel="methods" thread-count="2">
        <parameter name="browser" value="chrome"/>
        <packages>
            <package name="finalproject.tests"/>
        </packages>
    </test>

    <test name="Firefox" parallel="methods" thread-count="2">
        <parameter name="browser" value="firefox"/>
        <packages>
            <package name="finalproject.tests"/>
        </packages>
    </test>

</suite>